# ============================================================================
# .env.example - Template for environment variables
# ============================================================================
# 
# IMPORTANT INSTRUCTIONS:
# 1. Copy this file to `.env` in the project root: cp .env.example .env
# 2. Fill in the real values (don't commit .env to GitHub)
# 3. The .env file is already in .gitignore, so it won't be committed
# 4. For DigitalOcean, set these in the platform's environment variables panel
#
# DO NOT EDIT .env.example - only edit .env
# ============================================================================

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# SECRET_KEY: Random string used for cryptographic signing
# IMPORTANT: Must be kept SECRET!
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# For local dev, any value works. For production, use a strong random key.
SECRET_KEY=django-insecure-change-this-to-a-random-key-in-production

# DEBUG: Set to True for development, ALWAYS False in production
# When True: Shows detailed error pages with sensitive information (NEVER use in production)
# When False: Shows generic error page, errors logged to file
DEBUG=True

# ALLOWED_HOSTS: Comma-separated list of domains this app accepts requests from
# Used to prevent HTTP Host header attacks
# Local development: localhost,127.0.0.1
# Production: your-app.ondigitalocean.app,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# DJANGO SETTINGS MODULE
# ============================================================================

# Which settings file to use
# Options: config.dev (development) or config.prod (production)
DJANGO_SETTINGS_MODULE=config.dev

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# DATABASE_URL: Complete database connection string
# If this variable is NOT set, Django uses SQLite (db.sqlite3)
# If this variable IS set, Django uses PostgreSQL
#
# LOCAL DEVELOPMENT (uncomment to use local PostgreSQL):
# Requires PostgreSQL running on machine
# Format: postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/real_estate_db
#
# DIGITALOCEAN APP PLATFORM (auto-generated):
# DigitalOcean automatically provides this when you add a PostgreSQL component
# You don't need to set it manually - DigitalOcean does it for you

# DATABASE_URL is commented out, so SQLite will be used locally

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# For local development: Configure a test email account
# For production: Use company email service (Gmail, Sendgrid, AWS SES, etc.)

# Email provider hostname (SMTP server)
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
# SendGrid: smtp.sendgrid.net
EMAIL_HOST=smtp.gmail.com

# SMTP port
# Usually 587 (TLS) or 465 (SSL)
EMAIL_PORT=587

# Gmail account for sending emails
# IMPORTANT: 
# - Don't use your main password
# - Use "App Passwords" from Google Account Security settings
# - Your account: https://myaccount.google.com/security/
# - Generate app password: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com

# Gmail App Password (not your main account password)
# Must be 16 characters: xxxx xxxx xxxx xxxx
# Get it from: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Email address that appears in "From" field when users receive emails
# Doesn't have to be same as EMAIL_HOST_USER
# Example: noreply@propdz.com or support@yourdomain.com
DEFAULT_FROM_EMAIL=noreply@propdz.com

# ============================================================================
# HOW TO USE THIS FILE
# ============================================================================
#
# FOR LOCAL DEVELOPMENT:
# 1. cp .env.example .env
# 2. Edit .env with your local values
# 3. Don't commit .env to GitHub (already in .gitignore)
#
# FOR PRODUCTION (DigitalOcean):
# 1. Go to your app in DigitalOcean dashboard
# 2. Click "Settings" → "Environment"
# 3. Add each variable manually (don't upload .env file)
# 4. DigitalOcean automatically provides DATABASE_URL
# 5. Set DEBUG=False, DJANGO_SETTINGS_MODULE=config.prod
#
# ============================================================================

# ============================================================================
# QUICK START
# ============================================================================

# 1. Create .env file from this template:
#    cp .env.example .env

# 2. Generate a real SECRET_KEY:
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# 3. Set up Gmail (free):
#    - Go to https://myaccount.google.com/apppasswords
#    - Create "App Password" for Django
#    - Copy the 16-char password to EMAIL_HOST_PASSWORD

# 4. Run locally:
#    python manage.py migrate
#    python manage.py runserver

# 5. Deploy to DigitalOcean:
#    - Push to GitHub
#    - Connect repo to DigitalOcean App Platform
#    - Set each variable in DigitalOcean dashboard
#    - Deploy!
